# Focus left (alt + j)
alt - j : yabai -m window --focus west || yabai -m display --focus west

# Focus down (alt + k)
alt - k : yabai -m window --focus stack.next || yabai -m window --focus south

# Focus up (alt + l)
alt - l : yabai -m window --focus stack.prev || yabai -m window --focus north

# Focus right (alt + ;)
alt - 0x29 : yabai -m window --focus east || yabai -m display --focus east

# Move to left (alt + shift + j)
alt + shift - j : yabai -m window --warp west  || yabai -m window --display west

# Move to down (alt + shift + k)
alt + shift - k : yabai -m window --warp south

# Move to up (alt + shift + l)
alt + shift - l : yabai -m window --warp north

# Move to right (alt + shift + ;)
alt + shift - 0x29 : yabai -m window --warp east  || yabai -m window --display east

# Focus spaces (alt + <number>)
alt - 1 : yabai -m space --focus 1 || yabai -m space --focus recent
alt - 2 : yabai -m space --focus 2 || yabai -m space --focus recent
alt - 3 : yabai -m space --focus 3 || yabai -m space --focus recent
alt - 4 : yabai -m space --focus 4 || yabai -m space --focus recent
alt - 5 : yabai -m space --focus 5 || yabai -m space --focus recent
alt - 6 : yabai -m space --focus 6 || yabai -m space --focus recent
alt - 7 : yabai -m space --focus 7 || yabai -m space --focus recent
alt - 8 : yabai -m space --focus 8 || yabai -m space --focus recent
alt - 9 : yabai -m space --focus 9 || yabai -m space --focus recent
alt - 0 : yabai -m space --focus 10 || yabai -m space --focus recent

# Send window to space (alt + shift + <number>)
alt + shift - 1 : yabai -m window --space 1
alt + shift - 2 : yabai -m window --space 2
alt + shift - 3 : yabai -m window --space 3
alt + shift - 4 : yabai -m window --space 4
alt + shift - 5 : yabai -m window --space 5
alt + shift - 6 : yabai -m window --space 6
alt + shift - 7 : yabai -m window --space 7
alt + shift - 8 : yabai -m window --space 8
alt + shift - 9 : yabai -m window --space 9
alt + shift - 0 : yabai -m window --space 10

# Toggle split mode (alt + h/v)
alt - h : yabai -m window --toggle split
alt - v : yabai -m window --toggle split

# Resize window to left (alt + ctrl + shift + j)
alt + ctrl + shift - j : yabai -m window --resize left:-100:0; yabai -m window --resize right:-100:0

# Resize window to bottom (alt + ctrl + shift + ;)
alt + ctrl + shift - k : yabai -m window --resize bottom:0:100; yabai -m window --resize top:0:100

# Resize window to top (alt + ctrl + shift + l)
alt + ctrl + shift - l : yabai -m window --resize top:0:-100; yabai -m window --resize bottom:0:-100

# Resize window to right (alt + ctrl + shift + ;)
alt + ctrl + shift - 0x29 : yabai -m window --resize right:100:0; yabai -m window --resize left:100:0
